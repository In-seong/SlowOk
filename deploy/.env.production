APP_NAME=SlowOK
APP_ENV=production
APP_KEY=base64:여기에_키_생성_후_입력
APP_DEBUG=false
APP_URL=https://slowokuser.revuplan.com

LOG_CHANNEL=daily
LOG_LEVEL=error

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=slowok
DB_USERNAME=slowok_user
DB_PASSWORD=여기에_비밀번호_입력

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.revuplan.com

SANCTUM_STATEFUL_DOMAINS=slowokuser.revuplan.com,slowokadmin.revuplan.com

CACHE_STORE=file
QUEUE_CONNECTION=sync

GEMINI_API_KEY=여기에_Gemini_API키_입력
